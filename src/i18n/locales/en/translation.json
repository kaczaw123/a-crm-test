      "v1_2_0": {
        "date": "May 9, 2026",
        "title": "Advanced order filtering",
        "description": "We've introduced new order filtering mechanisms. You can now easily organize, sort, and search orders based on product mapping, fulfillment status, and delivery method. This simplifies warehouse management and significantly reduces the time it takes to find a specific order for picking."
      },
      "manual_reservation": {
        "date": "May 11, 2026",
        "title": "Manual reservation of goods",
        "description": "We've added the ability to manually reserve missing items in order details. This button appears directly in the order line, making it much easier to allocate a new shipment for partially completed orders."
      },
      "gls_de_integration": {
        "date": "May 13, 2026",
        "title": "GLS DE Integration",
        "description": "New feature! Integration with GLS DE for national and export rates. GLS is now available for custom integration, along with a ready-to-use Broker featuring connected price lists."
      },
      "bulk_labels": {
        "date": "May 13, 2026",
        "title": "Bulk label generation",
        "description": "We've added the ability to generate labels in bulk (Batch Label Generation) in the Fulfillment Engine. Simply select multiple orders from the list, set default parcel parameters for the entire order, and click the desired courier. This significantly streamlines workflows for bulk shipments and drastically reduces the time required to process shipments."
      },
      "multi_parcels": {
        "date": "14/05/2026",
        "title": "Generating multiple packages for one order (Multipacks)",
        "description": "Added the ability to dynamically create multiple labels from a single order. Parameterize the dimensions of each package, use the intelligent search engine to assign products, and generate all your packing lists with a single click!"
      }
    }
